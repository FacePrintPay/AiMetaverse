
# YesQuid Shell Guard
alias yq="$HOME/yesquid_shell_guard.sh"

# YesQuid Immutable Core Guard
/data/data/com.termux/files/home/yesquid_immutable_core.sh check >/dev/null 2>&1
alias am='agent-master'
alias dashboard='cd /data/data/com.termux/files/home/agent-dashboard && bash start-dashboard.sh'
source "$HOME/f6s_env.sh"
export PATH="$HOME/bin:$PATH"
export PATH="$PATH:$HOME/SovereignGTP/cli/sovereign"
export PATH="$PATH:$HOME/YesQuid"
alias yesquid_pro="bash $HOME/yesquid_pro_tasks.sh"
